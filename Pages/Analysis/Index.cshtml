@page "{cvId:int}"
@model Ai_Cv_Analyser.Pages.Analysis.IndexModel

@{
    Layout = null;
    ViewData["Title"] = "CV AI Analysis";
}
<title>@ViewData["Title"]</title>


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/3.34.1/tabler-icons.min.css">

<link href="/css/AnalyseStyle.css" rel="stylesheet">
    <link href="/css/site.css" rel="stylesheet">
<div class="page">
    <div class="page">
    <!-- HERO -->
    <div class="hero">
        <a asp-page="/Dashboard/Index" class="back-btn">
            ← Back
        </a>
        <h1>CV AI Analysis Report</h1>
        <p>Smart evaluation of your CV using AI insights</p>
    </div>

    @if (Model.Result == null)
    {
        <div class="panel">
            <p style="color:#b91c1c;">No analysis available.</p>
        </div>
    }
    else
    {
        <div class="grid">

            <!-- LEFT -->
            <div class="panel">

                <h3>Overall Score</h3>

                <div class="score">
                    @Model.Result.Score
                </div>

                <p style="text-align:center; opacity:.7;">Out of 100</p>

                <div class="rec-box">
                    @Model.Result.Summary
                </div>

            </div>

            <!-- RIGHT -->
            <div class="panel">

                <h3>Detailed Insights</h3>

                <!-- Strengths -->
                <h4 style="margin-top:10px;">Strengths</h4>
                <div>
                    @foreach (var item in Model.Result.Strengths)
                    {
                        if (!string.IsNullOrWhiteSpace(item))
                        {
                            <span class="skill">✔ @item</span>
                        }
                    }
                </div>

                <!-- Weaknesses -->
                <h4 style="margin-top:15px;">Weaknesses</h4>
                <div>
                    @foreach (var item in Model.Result.Weaknesses)
                    {
                        if (!string.IsNullOrWhiteSpace(item))
                        {
                            <span class="missing">✖ @item</span>
                        }
                    }
                </div>

                <!-- Suggested Skills -->
                <h4 style="margin-top:15px;">Suggested Skills</h4>
                <div>
                    @foreach (var item in Model.Result.SuggestedSkills)
                    {
                        if (!string.IsNullOrWhiteSpace(item))
                        {
                            <span class="skill">+ @item</span>
                        }
                    }
                </div>

                <!-- Projects -->
                <h4 style="margin-top:15px;">Suggested Projects</h4>
                <div>
                    @foreach (var item in Model.Result.SuggestedProjects)
                    {
                        if (!string.IsNullOrWhiteSpace(item))
                        {
                            <div class="roadmap-step">
                                🚀 @item
                            </div>
                        }
                    }
                </div>

            </div>

        </div>
    }

</div>
</div>