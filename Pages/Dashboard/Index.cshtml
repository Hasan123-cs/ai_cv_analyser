@page
@model Ai_Cv_Analyser.Pages.Dashboard.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "Dashboard";
}


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/3.34.1/tabler-icons.min.css" />

    <link href="/css/DashboardStyle.css" rel="stylesheet" />
<link rel="icon" href="/images/cvcv.png" />


    <div class="dashboard">

        <!-- TOP BAR -->

        <div class="topbar">
            <div class="logo">
                <i class="ti ti-brain"></i>
                AI CV Analyzer
            </div>

            <div class="user-box">
                <i class="ti ti-bell"></i>
                <form method="post" asp-page="/Account/Logout" style="display:inline;">
                    <button type="submit" class="logout-btn">
                        Sign Out
                    </button>
                </form>
                <div class="avatar">
                    @User.Identity.Name?.Substring(0,2).ToUpper()
                </div>
            </div>
        </div>

        <!-- HERO -->

        <div class="hero">

            <div>
                <span class="badge-ai">
                    <i class="ti ti-sparkles"></i>
                    AI Powered
                </span>

                <h1>
                    Welcome back,
                    @Model.fullName 👋
                </h1>

                <p>
                    You analyzed
                    <strong>@Model.Dashboard.TotalAnalyses</strong>
                    CVs and achieved a best score of
                    <strong>@Model.Dashboard.BestScore%</strong>
                </p>
            </div>

            <div class="score-circle">
                @Model.Dashboard.BestScore%
            </div>

        </div>

        <!-- STATS -->

        <div class="stats-grid">

            <div class="stat-card">
                <i class="ti ti-files"></i>
                <h3>@Model.Dashboard.TotalCVs</h3>
                <p>Total CVs</p>
            </div>

            <div class="stat-card">
                <i class="ti ti-chart-bar"></i>
                <h3>@Model.Dashboard.TotalAnalyses</h3>
                <p>Analyses</p>
            </div>

            <div class="stat-card">
                <i class="ti ti-briefcase"></i>
                <h3>@Model.Dashboard.TotalJobMatches</h3>
                <p>Job Matches</p>
            </div>

            <div class="stat-card">
                <i class="ti ti-award"></i>
                <h3>@Model.Dashboard.BestScore%</h3>
                <p>Best Score</p>
            </div>

        </div>

        <!-- ACTIONS -->

        <div class="actions">

            <a asp-page="/Upload/Index" class="action-card">
                <i class="ti ti-upload"></i>
                <span>Upload CV</span>
            </a>

            <a asp-page="/History/Index" class="action-card">
                <i class="ti ti-history"></i>
                <span>History</span>
            </a>

        </div>

        <!-- CONTENT -->

        <div class="content-grid">

            <div class="panel">

                <div class="panel-header">
                    <h4>My CVs</h4>
                    <span>@Model.CVs.Count()</span>
                </div>

                @foreach (var cv in Model.CVs)
                {
                    <div class="cv-row">

                        <div class="cv-left">
                            <i class="ti ti-file-text"></i>

                            <div>
                                <div>@cv.FileName</div>
                                <small>@cv.UploadedAt.ToShortDateString()</small>
                            </div>
                        </div>

                        <div class="cv-actions">
                            <a asp-page="/Analysis/Index"
                             class="analyze-link"
                               asp-route-cvId="@cv.Id">
                                Analyze
                            </a>

                            <a href="/JobMatch/Index/@cv.Id">
                                Match
                            </a>
                        </div>

                    </div>
                }

            </div>

            <div class="panel">

                <div class="panel-header">
                    <h4>Recent Analyses</h4>
                </div>

                @foreach (var item in Model.Dashboard.RecentAnalyses)
                {
                    <div class="analysis-row">

                        <div>
                            <div>@item.CVName</div>
                            <small>@item.Date.ToShortDateString()</small>
                        </div>

                        <div class="score-badge">
                            @item.Score%
                        </div>

                    </div>
                }

            </div>

        </div>

    </div>
<div id="loadingOverlay">
    <div class="text-center text-white">
        <div class="spinner-border"></div>
        <h4 class="mt-3">Analyzing CV...</h4>
    </div>
</div>
<script>
    document.querySelectorAll(".analyze-link")
        .forEach(link => {

            link.addEventListener("click", function () {

                document.getElementById("loadingOverlay")
                    .style.display = "flex";

            });

        });
</script>