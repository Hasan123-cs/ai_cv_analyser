@page
@model Ai_Cv_Analyser.Pages.History.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "History";
}
<link rel="icon" href="/images/cvcv.png" />
<title>@ViewData["Title"]</title>



    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/3.34.1/tabler-icons.min.css">

    <link href="/css/HistoryStyle.css" rel="stylesheet">
    <link href="/css/site.css" rel="stylesheet">


    <div class="history-page">

        <!-- HERO -->

        <div class="history-hero">
            <a asp-page="/Dashboard/Index" class="back-btn">
                ← Back
            </a>
            <div>
                <span class="history-pill">
                    <i class="ti ti-clock-history"></i>
                    Activity Center
                </span>

                <h1>History</h1>

                <p>
                    Track all analyses and job matching activities
                </p>
            </div>

            <div class="history-icon">
                <i class="ti ti-history"></i>
            </div>

        </div>

        <!-- FILTERS -->

        <div class="filter-box">

            <a asp-page="./Index"
               class="filter-btn @(Model.Filter == "All" ? "active" : "")">
                All
            </a>

            <a asp-page="./Index"
               asp-route-filter="Analyze"
               class="filter-btn @(Model.Filter == "Analyze" ? "active" : "")">
                Analyses
            </a>

            <a asp-page="./Index"
               asp-route-filter="JobMatch"
               class="filter-btn @(Model.Filter == "JobMatch" ? "active" : "")">
                Job Matches
            </a>

        </div>

        <!-- ITEMS -->

        <div class="history-grid">

            @foreach (var item in Model.HistoryItems)
            {
                bool analyze = item.Type == "Analyze";

                <div class="history-card">

                    <div class="card-top">

                        <div class="action-icon @(analyze ? "analyze" : "match")">

                            @if (analyze)
                            {
                                <i class="ti ti-chart-bar"></i>
                            }
                            else
                            {
                                <i class="ti ti-briefcase"></i>
                            }

                        </div>

                        <span class="date">
                            @item.Date.ToShortDateString()
                        </span>

                    </div>

                    <h5>@item.CVName</h5>

                    <div class="type-badge @(analyze ? "analyze-badge" : "match-badge")">
                        @(analyze ? "CV Analysis" : "Job Match")
                    </div>

                    <div class="score-box">
                        <span>Result</span>
                        <strong>@item.Score%</strong>
                    </div>

                </div>
            }

        </div>

    </div>

