@page "{id:int}"
@model Ai_Cv_Analyser.Pages.JobMatch.IndexModel

@{
    Layout=null;
    ViewData["Title"] = "AI Job Match";
}

    <meta charset="utf-8" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/3.34.1/tabler-icons.min.css">

    <link href="/css/JobMatchStyle.css" rel="stylesheet">
<link href="/css/site.css" rel="stylesheet">
<div class="page">

    <!-- HERO -->
    <div class="hero">
        <a asp-page="/Dashboard/Index" class="back-btn">
            ← Back
        </a>
        <h1>AI Job Match Analyzer</h1>
        <p>Compare your CV with any job and get smart AI insights instantly.</p>
    </div>

    <!-- GRID -->
    <div class="grid">

        <!-- LEFT PANEL -->
        <div class="panel">

            <h3>Job Input</h3>

            <form method="post" id="jobMatchForm">
                <input type="hidden" asp-for="CVId" />

                <label>Job Title</label>
                <input asp-for="JobTitle" class="form-control" placeholder="e.g. .NET Developer" />

                <label style="margin-top:10px;">Job Description</label>
                <textarea asp-for="JobDescription" rows="10" class="form-control"
                          placeholder="Paste job description..."></textarea>

                <button type="submit"
                        id="analyzeBtn"
                        class="ai-btn mt-3">
                    Analyze Match 🚀
                </button>
            </form>

        </div>

        <!-- RIGHT PANEL -->
        <div class="panel">

            <h3>Result</h3>

            @if (Model.Result != null)
            {

                <!-- SCORE -->
                <div class="score">
                    @Model.Result.MatchPercentage%
                </div>

                <div class="result-card">

                    <h4>Status</h4>

                    @if (Model.Result.MatchPercentage >= 80)
                    {
                        <div class="rec-box" style="border-left:5px solid #16a34a;">
                            Excellent Match 🚀
                        </div>
                    }
                    else if (Model.Result.MatchPercentage >= 60)
                    {
                        <div class="rec-box" style="border-left:5px solid #f59e0b;">
                            Good Match ⚠ Some skills missing
                        </div>
                    }
                    else
                    {
                        <div class="rec-box" style="border-left:5px solid #dc2626;">
                            Low Match ❌ Improve your skills
                        </div>
                    }

                    <!-- MATCHING SKILLS -->
                    <h4 style="margin-top:15px;">Matching Skills</h4>
                    <div>
                        @foreach (var skill in Model.Result.MatchingSkills)
                        {
                            <span class="skill">@skill</span>
                        }
                    </div>

                    <!-- MISSING SKILLS -->
                    <h4 style="margin-top:15px;">Missing Skills</h4>
                    <div>
                        @foreach (var skill in Model.Result.MissingSkills)
                        {
                            <span class="missing">@skill</span>
                        }
                    </div>

                    <!-- RECOMMENDATION -->
                    <h4 style="margin-top:15px;">AI Recommendation</h4>
                    <div class="rec-box">
                        @Model.Result.Recommendation
                    </div>

                    <!-- ROADMAP -->
                    <h4 style="margin-top:15px;">Learning Roadmap</h4>
                    <div>
                        @foreach (var step in Model.Result.Roadmap)
                        {
                            if (!string.IsNullOrWhiteSpace(step))
                            {
                                <div class="roadmap-step">
                                    👉 @step
                                </div>
                            }
                        }
                    </div>

                </div>

            }
            else
            {
                <p style="opacity:.7;">Submit a job to see AI analysis.</p>
            }

        </div>

    </div>

</div>
