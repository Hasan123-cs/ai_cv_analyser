@page
@model Ai_Cv_Analyser.Pages.Upload.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "Upload CV";
}
<link rel="icon" href="/images/cvcv.png" />

<title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/3.34.1/tabler-icons.min.css" />

    <link href="/css/UploadStyle.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet">

    <div class="upload-page">
       
        <div class="upload-card">
            <a asp-page="/Dashboard/Index" class="back-btn">
                ← Back
            </a>
            <div class="upload-header">
                
                <div class="upload-icon">
                    <i class="ti ti-file-upload"></i>
                </div>

                <h1>Upload Your CV</h1>

                <p>
                    Upload your resume and let AI analyze it
                    instantly.
                </p>

            </div>

            <form method="post"
                  enctype="multipart/form-data">

                <label class="upload-area">

                    <input asp-for="CvFile"
                           class="hidden-input"
                       id="cvInput"      />

                    <i class="ti ti-cloud-upload"></i>

                    <h4>Select CV File</h4>

                    <span>
                        PDF  supported
                    </span>

                </label>

                <span id="fileStatus" class="text-muted mt-2 d-block" style="margin-bottom:3vh !important">
                    No file selected
                    </span>
                <button type="submit"
                        class="upload-btn">

                    <i class="ti ti-upload"></i>
                    Upload CV

                </button>

                <div asp-validation-summary="ModelOnly" class="text-danger mt-3" id="validationBox"></div>

            </form>

        </div>

    </div>
<script>
    const input = document.getElementById("cvInput");
    const status = document.getElementById("fileStatus");
    const validationBox = document.getElementById("validationBox");
    input.addEventListener("change", function () {

        if (input.files.length === 0) {
            status.textContent = "No file selected";
            status.className = "text-muted d-block";
            return;
        }

        const file = input.files[0];
        const fileName = file.name.toLowerCase();
        // here we check if not a valid pdf 
        if (!fileName.endsWith(".pdf")) {
            status.textContent = "❌ Only PDF files are allowed!";
            status.className = "text-danger d-block";

            input.value = "";
            return;
        }

        status.textContent = "✅ CV selected: " + file.name;
        status.className = "text-success d-block";
        // to hide the server side validation after getting a valid pdf cv 
        if (validationBox) {
            validationBox.style.display = "none";
        }
    });
</script>